# Configuration Django
SECRET_KEY=votre_cle_secrete_ici
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# Configuration Base de données (PostgreSQL)
POSTGRES_DB=iglow_db
POSTGRES_USER=iglow_user
POSTGRES_PASSWORD=iglow_password
DATABASE_URL=postgres://iglow_user:iglow_password@db:5432/iglow_db

# Configuration Celery / Redis
CELERY_BROKER_URL=redis://redis:6379/0

# Firebase Admin SDK (backend) — obligatoire pour verifier les jetons Firebase
# Placez le JSON du compte de service dans backend/secrets/firebase-service-account.json
FIREBASE_CREDENTIALS_PATH=/app/secrets/firebase-service-account.json
# Alternative (une seule ligne JSON echappee) :
# FIREBASE_CREDENTIALS_JSON={"type":"service_account",...}

# IP autorisees pour Django /admin/ (vide = desactive). Exemple : 127.0.0.1,192.168.1.10
# ADMIN_ALLOWED_IPS=

# Configuration pgAdmin
PGADMIN_DEFAULT_EMAIL=admin@iglow.com
PGADMIN_DEFAULT_PASSWORD=admin
